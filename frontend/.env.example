# ────────────────────────────────────────────────────────────────
# frontend/.env  견본(템플릿).  복사해서 실제 값을 채워 쓴다:
#     cp .env.example .env
#
# ⚠️ 이 파일(.env.example)만 git에 올라간다. 실제 키가 든 .env / *.local 은
#    .gitignore 로 막혀 있어 절대 커밋되지 않는다.
#
# 참고: 키 찾기 우선순위는  ① frontend/*.local 파일  →  ② 아래 env(.env).
#   - 데스크톱 앱은 설정 화면(UI)에서 키를 입력하면 되고(가장 쉬움),
#     웹 dev 모드도 키 패널 [저장]이 *.local 파일을 만든다.
#   - 따라서 .env 는 "선택(폴백)"이다. UI/.local 로 이미 동작하면 안 채워도 된다.
#   - 1Password/Doppler 같은 시크릿 매니저로 자동 주입하려면 이 env 가 연동 지점이다.
# ────────────────────────────────────────────────────────────────

# ===== AI API 키 (핵심) ============================================
# Gemini (글·이미지 생성).  https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (ChatGPT 계열 글 생성).  https://platform.openai.com/api-keys
OPENAI_API_KEY=

# fal.ai (이미지 생성, Gemini 429 오프로드).  https://fal.ai/dashboard/keys
# 블로그는 FAL_API_KEY, 유튜브 백엔드는 FAL_KEY 로 같은 키를 공유한다.
FAL_API_KEY=

# ===== AI 제공자 선택 (선택) =======================================
# 비워두면 코드 기본값 사용. 명시하려면 주석 해제.
# AI_PROVIDER=gemini          # 글 생성 제공자 (gemini | openai)
# AI_IMAGE_PROVIDER=gemini    # 이미지 생성 제공자 (gemini | fal)
# OPENAI_TEXT_MODEL=          # OpenAI 글 모델명 지정 시

# ===== 아래는 보통 안 건드려도 됨 ===================================
# 데스크톱(Electron) 실행 시 앱이 자동 주입하거나 코드 기본값이 있다.
# 웹 단독 배포/특수 환경에서만 필요. 필요할 때 주석 해제 후 값 입력.

# --- Supabase (로그인/DB) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_AUTH_REDIRECT_TO=

# --- 백엔드 연결 URL ---
# BACKEND_URL=http://localhost:8000
# YOUTUBE_BACKEND_URL=http://localhost:8001

# --- Vercel KV (발행 카운터 등, 웹 배포 시) ---
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- 기능 플래그 ---
# NEXT_PUBLIC_ENABLE_PRODUCT_ATTACH=

# ⚠️ dev 전용 보안 우회 플래그(ALLOW_INSECURE_DEV_*)는 프로덕션 금지.
#    여기에 적지 말 것. 필요 시 로컬에서만 일시적으로 export.
