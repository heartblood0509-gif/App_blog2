node_modules/
.next/
.env
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
dist/
# build/ 디렉터리는 ignore 하지만 electron-builder 정적 리소스(앱 아이콘)는 예외.
# gitignore 사양상 디렉터리를 통째 ignore 하면 그 안의 재포함이 불가능하므로 build/* 패턴 사용.
build/*
!build/icon.png
.DS_Store
*.tsbuildinfo
accounts.json
.publish_counter.json
.claude/

# Electron packaging artifacts
electron/dist/
release/
release-*/
playwright-cache/
*.bak

# 워크트리 dev "빌려오기"는 의존성을 메인으로 향하는 symlink 로 만든다(scripts/dev-worktree.js).
# 위의 슬래시(/) 패턴은 "디렉터리"만 잡고 symlink 는 놓치므로, 슬래시 없는 패턴을 추가해
# 빌려온 심링크가 실수로 커밋되는 것을 막는다.
node_modules
playwright-cache
.venv
